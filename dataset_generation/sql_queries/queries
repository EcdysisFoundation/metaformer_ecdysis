SELECT img.image, uuid, morphos_id
    FROM spec_info_table AS s 
        JOIN public.samples_specimenimage AS img
        ON s.id = img.specimen_id) 
		JOIN public.taxonomy_morphospecies as morphos
		ON classification_id = morphos.id
    WHERE (s.acceptance = 2) AND s.classification_id > 0 AND s.sample_id IS NOT NULL;  


	

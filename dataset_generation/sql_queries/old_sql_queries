-- """ Queries for BugBox metadata retrieval """

SELECT morphos_name, morphos_id, cnt, specimen_id
FROM (
	SELECT morphos.name AS morphos_name, morphos.id as morphos_id, spec.id AS specimen_id, COUNT(*) AS cnt,
		ROW_NUMBER() OVER (partition by morphos.name ORDER BY COUNT(*) DESC) AS spec_count
		FROM public.taxonomy_morphospecies AS morphos 
		JOIN public.samples_specimen AS spec
		ON spec.classification_id = morphos.id
		GROUP BY morphos.name, spec.id, morphos.id
		ORDER BY spec.id 
) t
WHERE spec_count <= 1000




